@{
    ViewData["Title"] = "Home Page";
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
@*<script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>*@
<link href="https://cdn.datatables.net/1.11.4/css/jquery.dataTables.min.css" rel="stylesheet" />
<script type="text/javascript" src="https://cdn.datatables.net/1.11.4/js/jquery.dataTables.min.js"></script>

<form>

    <input type="text" id="txtSeatNumber" placeholder="Seat Number" style="margin-right:2px;" />
    <input type="text" id="txtCustomerName" placeholder="Customer Name" style="margin-right:2px;" />
    <input type="text" id="txtCustomerAddress" placeholder="Customer Address" style="margin-right:2px;" />
    <input type="text" id="txtTicketPrice" placeholder="Ticket Price" style="margin-right:2px;" />
    <input type="text" id="txtBusNumber" placeholder="Bus Number" style="margin-right:2px;" />
    <input type="text" id="txtOnboardingTime" placeholder="Onboarding Time" style="margin-right:2px;" />
</form>


<br />
<br />
<button id="btnSave" class="btn btn-success" style="margin-right:5px;">Save</button>
<button id="btnAddNew" class="btn btn-primary" style="margin-right:5px">Add New</button>
<br />
<br />

<table id="tblTicketPurchase" class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Seat Number</th>
            <th>CustomerName</th>
            <th>Customer Address</th>
            <th>Ticket Price</th>
            <th>Bus Number</th>
            <th>Onboarding Time</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<script type="text/javascript">
    $(document).ready(function () {
        $('#tblTicketPurchase').DataTable({
            "ajax": {
                "url": '/api/TicketPurchase',
                "dataSrc": ''
            },
            columns: [
                { data: 'SeatNumber' },
                { data: 'CustomerName' },
                { data: 'CustomerAddress' },
                { data: 'TicketPrice' },
                { data: 'BusNumber' },
                { data: 'OnboardingTime' },
                {
                    data: 'SeatNumber', render: function (data, type, row, meta) {
                        return "<button class='btn btn-primary' style='margin-right:5px' onClick=Edit(" + JSON.stringify(row) + ")  >Edit</button>" +
                            "<button class='btn btn-danger' style='margin-right:5px' onClick=Delete(" + JSON.stringify(row) + ")>Delete</button>";
                    }
                }
            ]
        });
        $("#btnSave").click(function () {
            var student = {
                SeatNumber: $("#txtSeatNumber").val(),
                CustomerName: $("#txtCustomerName").val(),
                CustomerAddress: $("#txtCustomerAddress").val(),
                TicketPrice: $("#txtTicketPrice").val(),
                BusNumber: $("#txtBusNumber").val(),
                OnboardingTime: $("#txtOnboardingTime").val(),
            };
            $.post("api/TicketPurchase", { student: student })
                .done(function (data) {
                    Reset();
                    ReloadGrid();
                    console.alart("Saved");
                });
        });
        $("#btnAddNew").click(function () {
            Reset();
            ReloadGrid();
        });
    });
    function Edit(oStudent) {
        $("#txtSeatNumber").val(oStudent.SeatNumber);
        $("#txtCustomerName").val(oStudent.CustomerName);
        $("#txtCustomerAddress").val(oStudent.CustomerAddress);
        $("#txtTicketPrice").val(oStudent.TicketPrice);
        $("#txtBusNumber").val(oStudent.BusNumber);
        $("#txtOnboardingTime").val(oStudent.OnboardingTime);
    }
    function Delete(oStudent) {
        $.ajax({
            url: "api/TicketPurchase/" + oStudent.SeatNumber,
            type: 'DELETE',
            success: function (result) {
                alert("Deletted");
                ReloadGrid();
            }
        })
    }
    function Reset() {
        $("#txtSeatNumber").val(null);
        $("#txtCustomerName").val(null);
        $("#txtCustomerAddress").val(null);
        $("#txtTicketPrice").val(null);
        $("#txtBusNumber").val(null);
        $("#txtOnboardingTime").val(null);
    }
    function ReloadGrid() {
        $('#tblTicketPurchase').DataTable().clear();
        $('#tblTicketPurchase').DataTable().ajax.reload();
    }
</script>


@section Scripts
{
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>


}